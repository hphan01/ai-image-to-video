# =============================================================================
# AI Image-to-Video Generator — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your API keys.
# Only HF_API_KEY is required to use the free tier.
# =============================================================================

# ------- FREE TIER (Required) -------
# Hugging Face API key — used for the free Wan2.1 video model and MusicGen audio
# Get your key at: https://huggingface.co/settings/tokens
HF_API_KEY=hf_your_huggingface_token_here

# ------- PAID PROVIDERS (Optional) -------
# Luma Dream Machine — https://lumalabs.ai/dream-machine/api/keys
LUMA_API_KEY=

# Runway Gen4 — https://dev.runwayml.com
RUNWAYML_API_SECRET=

# fal.ai — required for BOTH Kling AI and Luma image hosting
# https://fal.ai/dashboard/keys
FAL_KEY=
